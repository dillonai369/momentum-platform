# =====================================================================
# MOMENTUM PLATFORM — Environment Variables
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local` to git.
# =====================================================================

# --- Supabase ---------------------------------------------------------
# Get from supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Clerk ------------------------------------------------------------
# Get from clerk.com → Application → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# --- GoHighLevel (Momentum CRM sub-account) ---------------------------
# Get from GHL → Momentum CRM sub-account → Settings → Business Profile → API Key
GHL_MOMENTUM_API_KEY=
GHL_MOMENTUM_LOCATION_ID=

# --- Resend (transactional email) -------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@momentummarketing.io

# --- Cal.com (booking) ------------------------------------------------
CAL_API_KEY=
CAL_USERNAME_RYAN=ryan-heagney

# --- Meta Lead Ads webhook --------------------------------------------
# Verify token (you choose this, must match Meta app settings)
META_LEADS_VERIFY_TOKEN=
META_APP_SECRET=

# --- Platform ---------------------------------------------------------
# Used for absolute URLs in emails, webhooks, etc.
NEXT_PUBLIC_PLATFORM_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_TENANT_SLUG=momentum
